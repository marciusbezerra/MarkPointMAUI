<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="MarkPointMAUI.MainPage"
             xmlns:local="clr-namespace:MarkPointMAUI"
             x:DataType="local:MainPageViewModel">
    <Grid RowDefinitions="*,Auto,Auto"
          ColumnDefinitions="*">
        <WebView x:Name="MapView"
                 Grid.Row="0" />
        <Button x:Name="MarkButton"
                Text="Marcar ponto"
                Grid.Row="1"
                Margin="20"
                Clicked="OnMarkPointClicked" />
        <CollectionView x:Name="PointsList"
                        Grid.Row="2"
                        HeightRequest="250"
                        Margin="10"
                        ItemsSource="{Binding Points}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:MakedPointViewModel">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Padding="0, 2">
                        <Label Text="{Binding DisplayText}" Grid.Column="0" VerticalOptions="Center" />
                        <!-- botões somente ícone (usa emoji para evitar adicionar imagens/fontes) -->
                        <Button Text="✏️"
                                Clicked="OnEditClicked"
                                Grid.Column="1"
                                VerticalOptions="Center"
                                BackgroundColor="Transparent"
                                WidthRequest="40"
                                HeightRequest="40"
                                FontSize="18"
                                CornerRadius="20"
                                AutomationProperties.Name="Editar" />
                        <Button Text="📍"
                                Clicked="OnNavigateClicked"
                                Grid.Column="2"
                                VerticalOptions="Center"
                                BackgroundColor="Transparent"
                                WidthRequest="40"
                                HeightRequest="40"
                                FontSize="18"
                                CornerRadius="20"
                                AutomationProperties.Name="Ir para" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>